# ─────────────────────────────────────────────────────────────
# AI Support Ticket Classifier — environment configuration
# Copy to `.env` and fill in the real values. Never commit `.env`.
# n8n auto-loads process env vars; access them in nodes as {{ $env.NAME }}.
# ─────────────────────────────────────────────────────────────

# ── LLM (OpenAI) ─────────────────────────────────────────────
OPENAI_API_KEY= #fill
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=400

# ── File paths ───────────────────────────────────────────────
# Self-hosted n8n restricts file I/O to /home/node/.n8n-files by
# default (via N8N_RESTRICT_FILE_ACCESS_TO). Place your CSV there,
# or override that env var on the n8n container if you need a
# different location.
INPUT_CSV_PATH=/home/node/.n8n-files/sample_tickets.csv
OUTPUT_CSV_PATH=/home/node/.n8n-files/enriched_tickets.csv

# ── Schedule trigger (cron; default = every 6 hours) ─────────
CRON_SCHEDULE=0 */6 * * *

# ── Webhook ──────────────────────────────────────────────────
WEBHOOK_PATH=tickets
# Optional shared secret. If empty, the auth check is skipped.
WEBHOOK_TOKEN=

# ── Routing (all departments hit the same inbox per the assignment,
#    but each is parameterised so real deployments can point them
#    elsewhere without editing the workflow). ─────────────────
SUPPORT_EMAIL=harelaifactory@gmail.com
FINANCE_EMAIL=harelaifactory@gmail.com
ENGINEERING_EMAIL=harelaifactory@gmail.com
PRODUCT_EMAIL=harelaifactory@gmail.com
SALES_EMAIL=harelaifactory@gmail.com
GENERAL_SUPPORT_EMAIL=harelaifactory@gmail.com
MANUAL_REVIEW_EMAIL=harelaifactory@gmail.com

# ── Confidence threshold below which tickets go to Manual Review ─
CONFIDENCE_THRESHOLD=0.60

# ── SMTP (Gmail example — use an App Password, NOT your login) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.address@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Ticket Bot <your.address@gmail.com>"
